# StockClerk Backend Environment Configuration

# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stockclerk

# Redis (for BullMQ job queues)
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-chars
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Encryption Key for storing channel credentials (must be 32+ characters)
ENCRYPTION_KEY=your-32-char-encryption-key-here!

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:5173

# Wix Integration
WIX_CLIENT_ID=
WIX_CLIENT_SECRET=
WIX_REDIRECT_URI=http://localhost:3001/api/oauth/wix/callback

# Shopify Integration
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_REDIRECT_URI=http://localhost:3001/api/oauth/shopify/callback

# Uber Eats Integration
UBER_EATS_CLIENT_ID=
UBER_EATS_CLIENT_SECRET=
UBER_EATS_REDIRECT_URI=http://localhost:3001/api/oauth/uber-eats/callback
